// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`Visual DOM Snapshot Tests > Game over overlay snapshot 1`] = `
"
            <div class="modal-content">
              <h2 id="winner-text">Weiß gewinnt!</h2>
              <div id="game-over-stats" class="game-over-stats" style="
                  margin: 1rem 0;
                  padding: 1rem;
                  background: rgba(255, 255, 255, 0.05);
                  border-radius: 8px;
                  display: none;
                "></div>
              <button id="postgame-analysis-btn" class="btn-primary" style="margin-top: 0.5rem; display: none">
                📊 Nachspiel-Analyse
              </button>
              <button id="restart-btn-overlay" class="btn-primary">Neues Spiel</button>
              <button id="close-game-over-btn" class="btn-secondary">Schließen</button>
            </div>
          "
`;

exports[`Visual DOM Snapshot Tests > Initial setup phase snapshot 1`] = `
"

  
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Ein Schachspiel auf einem 9x9 Brett mit neuen Figuren und Regeln.">
    <meta name="theme-color" content="#0a0e27">
    <title>Schach 9x9</title>
    <link rel="manifest" href="manifest.json">
    <link rel="icon" type="image/png" href="/schach9x9/icon-192.png">
    <link rel="stylesheet" href="style.css">
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="">
    <link rel="stylesheet" href="css/notifications.css">
    <link rel="stylesheet" href="css/menu.css">
    <link rel="stylesheet" href="css/tutorial.css">
    <link rel="stylesheet" href="css/skins.css">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&amp;display=swap" rel="stylesheet">

    <!-- Import Map for Three.js (using jsDelivr CDN for better reliability) -->
    <script type="importmap">
      {
        "imports": {
          "three": "https://cdn.jsdelivr.net/npm/three@0.160.1/build/three.module.js",
          "three/examples/jsm/controls/OrbitControls.js": "https://cdn.jsdelivr.net/npm/three@0.160.1/examples/jsm/controls/OrbitControls.js"
        }
      }
    </script>
  

  
    <!-- Hidden H1 for Accessibility -->
    <h1 class="hidden">Schach 9x9</h1>

    <!-- Global SVG Assets (Hidden) -->
    <svg style="position: absolute; width: 0; height: 0; overflow: hidden" aria-hidden="true">
      <defs>
        <!-- Neon White Glow -->
        <filter id="filter-neon-glow-white">
          <feGaussianBlur stdDeviation="2" result="coloredBlur"></feGaussianBlur>
          <feMerge>
            <feMergeNode in="coloredBlur"></feMergeNode>
            <feMergeNode in="SourceGraphic"></feMergeNode>
          </feMerge>
        </filter>
        <!-- Neon Black Glow -->
        <filter id="filter-neon-glow-black">
          <feGaussianBlur stdDeviation="2" result="coloredBlur"></feGaussianBlur>
          <feMerge>
            <feMergeNode in="coloredBlur"></feMergeNode>
            <feMergeNode in="SourceGraphic"></feMergeNode>
          </feMerge>
        </filter>
      </defs>
    </svg>

    <!-- TOP LAYER: System-level notifications, errors, and loading -->
    <div id="top-layer">
      <!-- Toast Notifications Container -->
      <div id="toast-container"></div>

      <!-- Spinner Overlay -->
      <div id="spinner-overlay" class="modal-overlay hidden">
        <div class="ai-thinking-panel">
          <div class="spinner"></div>
          <div style="margin-top: 16px; font-size: 1.2em; font-weight: 600">KI rechnet…</div>
          <div class="ai-status">
            <div id="ai-depth">Berechne…</div>
            <div id="ai-nodes">0 Positionen</div>
            <div id="ai-best-move"></div>
          </div>
          <div class="progress-bar-container">
            <div id="progress-fill"></div>
          </div>
        </div>
      </div>

      <!-- Error Overlay -->
      <div id="error-overlay" class="modal-overlay hidden">
        <div class="critical-error-content">
          <h2>Ein Fehler ist aufgetreten</h2>
          <div id="error-message"></div>
          <button class="btn-primary" onclick="location.reload()">Neustarten</button>
        </div>
      </div>
    </div>

    <!-- Sheet backdrop (mobile bottom sheets) -->
    <div id="sheet-backdrop" class="sheet-backdrop hidden" aria-hidden="true"></div>

    <!-- GAME LAYER: Main board and game controls -->
    <div id="game-layer">
      <div id="app-container">
        <!-- Minimal Header -->
        <header class="minimal-header">
          <div class="logo">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="logo-icon" aria-hidden="true">
              <rect width="18" height="18" x="3" y="3" rx="2"></rect>
              <path d="M7 7h10"></path>
              <path d="M7 12h10"></path>
              <path d="M7 17h10"></path>
              <path d="M12 3v18"></path>
            </svg>
            <span class="logo-text">Schach 9x9</span>
          </div>
          <div class="header-center">
            <div id="status-display" data-testid="status-display" class="status-pill">Weiß: Wähle einen Korridor für den König</div>
            <div class="header-clocks" aria-label="Uhren">
              <span class="header-clock header-clock-opp" id="header-clock-black">5:00</span>
              <span class="header-clock-sep" aria-hidden="true">·</span>
              <span class="header-clock header-clock-self" id="header-clock-white">5:00</span>
            </div>
          </div>
          <button id="menu-btn" class="icon-btn" aria-label="Menü öffnen">
            <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
              <line x1="3" y1="12" x2="21" y2="12"></line>
              <line x1="3" y1="6" x2="21" y2="6"></line>
              <line x1="3" y1="18" x2="21" y2="18"></line>
            </svg>
          </button>
        </header>

        <!-- Main Game Area -->
        <div class="game-area" role="main">
          <!-- Opponent Info / Clock -->
          <div class="player-info opponent">
            <div class="player-details">
              <div style="display: flex; align-items: center">
                <div class="player-avatar">
                  <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 8V4H8"></path>
                    <rect width="16" height="12" x="4" y="8" rx="2"></rect>
                    <path d="M2 14h2"></path>
                    <path d="M20 14h2"></path>
                    <path d="M15 13v2"></path>
                    <path d="M9 13v2"></path>
                  </svg>
                </div>
                <div>
                  <div class="player-name" id="opponent-name">Gegner</div>
                  <div class="captured-pieces" id="captured-white"></div>
                </div>
              </div>
            </div>
            <div class="clock-display" id="clock-black">5:00</div>
          </div>

          <!-- Opening Name Display -->
          <div id="opening-name-container" class="hidden">
            Eröffnung: <span id="opening-name">...</span>
          </div>

          <!-- Chess Board -->
          <div id="board-container">
            <!-- 3D Battle Chess Container -->
            <div id="battle-chess-3d-container"></div>

            <div id="board-wrapper" aria-label="Schachbrett" role="region">
              <div id="board" data-testid="board" class="board-9x9" style="grid-template-columns: repeat(9, 1fr); grid-template-rows: repeat(9, 1fr);"><div class="cell light" data-r="0" data-c="0" draggable="true"></div><div class="cell dark" data-r="0" data-c="1" draggable="true"></div><div class="cell light border-right" data-r="0" data-c="2" draggable="true"></div><div class="cell dark" data-r="0" data-c="3" draggable="true"></div><div class="cell light" data-r="0" data-c="4" draggable="true"></div><div class="cell dark border-right" data-r="0" data-c="5" draggable="true"></div><div class="cell light" data-r="0" data-c="6" draggable="true"></div><div class="cell dark" data-r="0" data-c="7" draggable="true"></div><div class="cell light" data-r="0" data-c="8" draggable="true"></div><div class="cell dark" data-r="1" data-c="0" draggable="true"></div><div class="cell light" data-r="1" data-c="1" draggable="true"></div><div class="cell dark border-right" data-r="1" data-c="2" draggable="true"></div><div class="cell light" data-r="1" data-c="3" draggable="true"></div><div class="cell dark" data-r="1" data-c="4" draggable="true"></div><div class="cell light border-right" data-r="1" data-c="5" draggable="true"></div><div class="cell dark" data-r="1" data-c="6" draggable="true"></div><div class="cell light" data-r="1" data-c="7" draggable="true"></div><div class="cell dark" data-r="1" data-c="8" draggable="true"></div><div class="cell light border-bottom" data-r="2" data-c="0" draggable="true"></div><div class="cell dark border-bottom" data-r="2" data-c="1" draggable="true"></div><div class="cell light border-right border-bottom" data-r="2" data-c="2" draggable="true"></div><div class="cell dark border-bottom" data-r="2" data-c="3" draggable="true"></div><div class="cell light border-bottom" data-r="2" data-c="4" draggable="true"></div><div class="cell dark border-right border-bottom" data-r="2" data-c="5" draggable="true"></div><div class="cell light border-bottom" data-r="2" data-c="6" draggable="true"></div><div class="cell dark border-bottom" data-r="2" data-c="7" draggable="true"></div><div class="cell light border-bottom" data-r="2" data-c="8" draggable="true"></div><div class="cell dark" data-r="3" data-c="0" draggable="true"></div><div class="cell light" data-r="3" data-c="1" draggable="true"></div><div class="cell dark border-right" data-r="3" data-c="2" draggable="true"></div><div class="cell light" data-r="3" data-c="3" draggable="true"></div><div class="cell dark" data-r="3" data-c="4" draggable="true"></div><div class="cell light border-right" data-r="3" data-c="5" draggable="true"></div><div class="cell dark" data-r="3" data-c="6" draggable="true"></div><div class="cell light" data-r="3" data-c="7" draggable="true"></div><div class="cell dark" data-r="3" data-c="8" draggable="true"></div><div class="cell light" data-r="4" data-c="0" draggable="true"></div><div class="cell dark" data-r="4" data-c="1" draggable="true"></div><div class="cell light border-right" data-r="4" data-c="2" draggable="true"></div><div class="cell dark" data-r="4" data-c="3" draggable="true"></div><div class="cell light" data-r="4" data-c="4" draggable="true"></div><div class="cell dark border-right" data-r="4" data-c="5" draggable="true"></div><div class="cell light" data-r="4" data-c="6" draggable="true"></div><div class="cell dark" data-r="4" data-c="7" draggable="true"></div><div class="cell light" data-r="4" data-c="8" draggable="true"></div><div class="cell dark border-bottom" data-r="5" data-c="0" draggable="true"></div><div class="cell light border-bottom" data-r="5" data-c="1" draggable="true"></div><div class="cell dark border-right border-bottom" data-r="5" data-c="2" draggable="true"></div><div class="cell light border-bottom" data-r="5" data-c="3" draggable="true"></div><div class="cell dark border-bottom" data-r="5" data-c="4" draggable="true"></div><div class="cell light border-right border-bottom" data-r="5" data-c="5" draggable="true"></div><div class="cell dark border-bottom" data-r="5" data-c="6" draggable="true"></div><div class="cell light border-bottom" data-r="5" data-c="7" draggable="true"></div><div class="cell dark border-bottom" data-r="5" data-c="8" draggable="true"></div><div class="cell light" data-r="6" data-c="0" draggable="true"></div><div class="cell dark" data-r="6" data-c="1" draggable="true"></div><div class="cell light border-right" data-r="6" data-c="2" draggable="true"></div><div class="cell dark" data-r="6" data-c="3" draggable="true"></div><div class="cell light" data-r="6" data-c="4" draggable="true"></div><div class="cell dark border-right" data-r="6" data-c="5" draggable="true"></div><div class="cell light" data-r="6" data-c="6" draggable="true"></div><div class="cell dark" data-r="6" data-c="7" draggable="true"></div><div class="cell light" data-r="6" data-c="8" draggable="true"></div><div class="cell dark" data-r="7" data-c="0" draggable="true"></div><div class="cell light" data-r="7" data-c="1" draggable="true"></div><div class="cell dark border-right" data-r="7" data-c="2" draggable="true"></div><div class="cell light" data-r="7" data-c="3" draggable="true"></div><div class="cell dark" data-r="7" data-c="4" draggable="true"></div><div class="cell light border-right" data-r="7" data-c="5" draggable="true"></div><div class="cell dark" data-r="7" data-c="6" draggable="true"></div><div class="cell light" data-r="7" data-c="7" draggable="true"></div><div class="cell dark" data-r="7" data-c="8" draggable="true"></div><div class="cell light" data-r="8" data-c="0" draggable="true"></div><div class="cell dark" data-r="8" data-c="1" draggable="true"></div><div class="cell light border-right" data-r="8" data-c="2" draggable="true"></div><div class="cell dark" data-r="8" data-c="3" draggable="true"></div><div class="cell light" data-r="8" data-c="4" draggable="true"></div><div class="cell dark border-right" data-r="8" data-c="5" draggable="true"></div><div class="cell light" data-r="8" data-c="6" draggable="true"></div><div class="cell dark" data-r="8" data-c="7" draggable="true"></div><div class="cell light" data-r="8" data-c="8" draggable="true"></div></div>
            <div class="col-labels" style="grid-template-columns: repeat(9, 1fr);"><span class="coord-label">a</span><span class="coord-label">b</span><span class="coord-label">c</span><span class="coord-label">d</span><span class="coord-label">e</span><span class="coord-label">f</span><span class="coord-label">g</span><span class="coord-label">h</span><span class="coord-label">i</span></div><div class="row-labels" style="grid-template-rows: repeat(9, 1fr);"><span class="coord-label">9</span><span class="coord-label">8</span><span class="coord-label">7</span><span class="coord-label">6</span><span class="coord-label">5</span><span class="coord-label">4</span><span class="coord-label">3</span><span class="coord-label">2</span><span class="coord-label">1</span></div></div>

            <!-- Opening Trainer panel (filled by OpeningTrainerMenu) -->
            <div id="opening-trainer-container"></div>
          </div>

          <!-- Evaluation Graph -->
          <div id="eval-graph-container" class="eval-graph-container hidden">
            <svg id="eval-graph" preserveAspectRatio="none" viewBox="0 0 1000 100"></svg>
          </div>

          <!-- Player Info / Clock -->
          <div class="player-info self">
            <div class="player-details">
              <div style="display: flex; align-items: center">
                <div class="player-avatar">
                  <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path>
                    <circle cx="12" cy="7" r="4"></circle>
                  </svg>
                </div>
                <div>
                  <div class="player-name">Du</div>
                  <div class="captured-pieces" id="captured-black"></div>
                </div>
              </div>
            </div>
            <div class="clock-display" id="clock-white">5:00</div>
          </div>

          <!-- Action Bar (UI-A: primary + overflow) -->
          <div class="action-bar" role="toolbar" aria-label="Spiel-Aktionen">
            <div class="action-bar-primary">
              <button id="undo-btn" class="action-icon-btn" title="Rückgängig (U)" aria-label="Rückgängig (U)" data-tooltip="Rückgängig (U)" data-shortcut="U">
                <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none">
                  <path d="M3 7v6h6"></path>
                  <path d="M21 17a9 9 0 0 0-9-9 9 9 0 0 0-6 2.3L3 13"></path>
                </svg>
                <span class="action-label">Rückgängig</span>
                <span class="action-shortcut">U</span>
              </button>
              <button id="hint-btn" class="action-icon-btn" title="Tipps anzeigen (H)" aria-label="Tipps anzeigen (H)" data-tooltip="Tipps anzeigen (H)" data-shortcut="H">
                <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none">
                  <path d="M9.663 17h4.673M12 3v1M6.343 4.343l-.707-.707M17.657 4.343l.707-.707M4 12h1M19 12h1M12 21a9 9 0 0 0 9-9c0-4.97-4.03-9-9-9s-9 4.03-9 9a9 9 0 0 0 9 9z"></path>
                </svg>
                <span class="action-label">Tipps</span>
                <span class="action-shortcut">H</span>
              </button>
              <button id="best-move-btn" class="action-icon-btn" title="Besten Zug anzeigen (B)" aria-label="Besten Zug anzeigen (B)" data-tooltip="Besten Zug anzeigen (B)" data-shortcut="B">
                <svg viewBox="0 0 24 24" width="24" height="24" stroke="#22c55e" stroke-width="2" fill="none">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
                <span class="action-label">Bester Zug</span>
                <span class="action-shortcut">B</span>
              </button>
              <button id="toggle-analysis-btn" class="action-icon-btn" title="Engine-Analyse (A)" aria-label="Engine-Analyse (A)" data-tooltip="Engine-Analyse (A)" data-shortcut="A">
                <svg viewBox="0 0 24 24" width="24" height="24" stroke="var(--accent-primary)" stroke-width="2" fill="none">
                  <path d="M12 20v-8m-4 8v-4m8 4v-6m-12 6h16"></path>
                </svg>
                <span class="action-label">Analyse</span>
                <span class="action-shortcut">A</span>
              </button>
            </div>

            <div class="action-bar-more">
              <button id="action-more-btn" class="action-icon-btn" title="Weitere Aktionen" aria-label="Weitere Aktionen" aria-haspopup="menu" aria-expanded="false" aria-controls="action-overflow-menu" data-tooltip="Mehr">
                <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none">
                  <circle cx="5" cy="12" r="1.5" fill="currentColor"></circle>
                  <circle cx="12" cy="12" r="1.5" fill="currentColor"></circle>
                  <circle cx="19" cy="12" r="1.5" fill="currentColor"></circle>
                </svg>
                <span class="action-label">Mehr</span>
              </button>
              <div id="action-overflow-menu" class="action-overflow-menu hidden" role="menu" aria-label="Weitere Aktionen">
                <button id="threats-btn" class="action-icon-btn" role="menuitem" title="Drohungen visualisieren (T)" aria-label="Drohungen visualisieren (T)" data-tooltip="Drohungen (T)" data-shortcut="T">
                  <svg viewBox="0 0 24 24" width="24" height="24" stroke="#ef4444" stroke-width="2" fill="none">
                    <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
                    <line x1="12" y1="9" x2="12" y2="13"></line>
                    <line x1="12" y1="17" x2="12.01" y2="17"></line>
                  </svg>
                  <span class="action-label">Drohungen</span>
                  <span class="action-shortcut">T</span>
                </button>
                <button id="opportunities-btn" class="action-icon-btn" role="menuitem" title="Chancen anzeigen" aria-label="Chancen anzeigen" data-tooltip="Chancen">
                  <svg viewBox="0 0 24 24" width="24" height="24" stroke="#f59e0b" stroke-width="2" fill="none">
                    <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                  </svg>
                  <span class="action-label">Chancen</span>
                </button>
                <button id="toggle-opening-book-btn" class="action-icon-btn" role="menuitem" title="Eröffnungsbuch" aria-label="Eröffnungsbuch" data-tooltip="Eröffnungsbuch">
                  <svg viewBox="0 0 24 24" width="24" height="24" stroke="#9f5fef" stroke-width="2" fill="none">
                    <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
                    <path d="M6.5 17H20"></path>
                    <path d="M12.5 17V10.5"></path>
                    <path d="M9 13h7"></path>
                    <path d="M9 17h7"></path>
                  </svg>
                  <span class="action-label">Eröffnung</span>
                </button>
                <button id="toggle-3d-btn" class="action-icon-btn" role="menuitem" title="3D-Schlachtmodus (3)" aria-label="3D-Schlachtmodus (3)" data-tooltip="3D (3)" data-shortcut="3">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path>
                    <polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline>
                    <line x1="12" y1="22.08" x2="12" y2="12"></line>
                  </svg>
                  <span class="action-label">3D</span>
                  <span class="action-shortcut">3</span>
                </button>
                <div id="skin-selector-wrapper" class="action-icon-btn skin-selector-wrapper" role="menuitem" title="Figuren-Skin auswählen" aria-label="Figuren-Skin auswählen" data-tooltip="Figuren-Skin">
                  <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="13.5" cy="6.5" r="2.5"></circle>
                    <circle cx="17.5" cy="10.5" r="2.5"></circle>
                    <circle cx="8.5" cy="7.5" r="2.5"></circle>
                    <circle cx="6.5" cy="12.5" r="2.5"></circle>
                    <path d="M12 22a10 10 0 1 1 0-20 10 10 0 0 1 0 20z"></path>
                  </svg>
                  <span class="action-label">Skin</span>
                  <select id="skin-selector" class="skin-selector" aria-label="Figuren-Skin auswählen" tabindex="-1">
                    <option value="classic">Klassisch</option>
                    <option value="modern">Modern</option>
                    <option value="pixel">Pixel</option>
                    <option value="infernale">Infernale</option>
                    <option value="wood">Holz</option>
                    <option value="neon">Neon</option>
                    <option value="minimalist">Minimalistisch</option>
                    <option value="frost">Frost</option>
                  </select>
                </div>
                <button id="info-toggle-btn" class="action-icon-btn" role="menuitem" title="Info / Zugprotokoll" aria-label="Info / Zugprotokoll" data-tooltip="Info">
                  <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none">
                    <circle cx="12" cy="12" r="10"></circle>
                    <line x1="12" y1="16" x2="12" y2="12"></line>
                    <line x1="12" y1="8" x2="12.01" y2="8"></line>
                  </svg>
                  <span class="action-label">Info</span>
                </button>
                <button id="fullscreen-btn" class="action-icon-btn" role="menuitem" title="Vollbild (F)" aria-label="Vollbild (F)" data-tooltip="Vollbild (F)" data-shortcut="F">
                  <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none">
                    <path d="M8 3H5a2 2 0 0 0-2 2v3"></path>
                    <path d="M21 8V5a2 2 0 0 0-2-2h-3"></path>
                    <path d="M3 16v3a2 2 0 0 0 2 2h3"></path>
                    <path d="M16 21h3a2 2 0 0 0 2-2v-3"></path>
                  </svg>
                  <span class="action-label">Vollbild</span>
                  <span class="action-shortcut">F</span>
                </button>
              </div>
            </div>
          </div>
        </div>

        <!-- PANEL LAYER: Contextual side/top panels -->
        <div id="panel-layer">
          <!-- Analysis Panel (Deep Analysis) -->
          <div id="analysis-panel" class="analysis-panel hidden">
            <div class="analysis-header">
              <h3>Tiefenanalyse</h3>
              <button id="close-analysis-btn" class="close-icon-btn">×</button>
            </div>
            <div class="analysis-body">
              <div class="eval-section">
                <div class="eval-bar-container">
                  <div id="eval-bar" class="eval-bar"></div>
                </div>
                <div id="eval-score" class="eval-score">0.00</div>
              </div>
              <div class="top-moves-section">
                <h4>Top Züge</h4>
                <div id="top-moves-content" class="top-moves-list">
                  <!-- Top moves injected by JS -->
                </div>
              </div>
              <div class="analysis-controls">
                <div class="analysis-info" id="analysis-engine-info">Tiefe: - | Knoten: -</div>
                <button id="continuous-analysis-btn" class="btn-secondary small-btn">
                  🔄 Kontinuierlich
                </button>
              </div>

              <!-- Live Search Progress -->
              <div class="live-search-progress" style="
                  margin-top: 1rem;
                  padding: 0.75rem;
                  background: rgba(0, 0, 0, 0.2);
                  border-radius: 8px;
                  font-size: 0.85rem;
                ">
                <div style="
                    display: grid;
                    grid-template-columns: repeat(2, 1fr);
                    gap: 0.5rem;
                    margin-bottom: 0.5rem;
                  ">
                  <div><strong>Tiefe:</strong> <span id="live-depth">-</span></div>
                  <div><strong>Knoten:</strong> <span id="live-nodes">-</span></div>
                  <div><strong>Bewertung:</strong> <span id="live-score">-</span></div>
                  <div><strong>Zeit:</strong> <span id="live-time">-</span></div>
                </div>
                <div style="margin-top: 0.5rem">
                  <strong>Hauptvariante:</strong>
                  <span id="live-pv" style="color: var(--accent-primary); font-family: monospace">-</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Opening Book Panel -->
          <div id="opening-book-panel" class="opening-book-panel hidden">
            <div class="opening-book-header">
              <h3>Eröffnungsbuch</h3>
              <button id="close-opening-book-btn" class="close-icon-btn">×</button>
            </div>
            <div class="opening-book-body">
              <!-- Current Opening Display -->
              <div id="current-opening-display" class="current-opening-section hidden">
                <h4>Aktuelle Eröffnung</h4>
                <div class="current-opening-info">
                  <div class="current-opening-name-row">
                    <span id="current-opening-name" class="current-opening-name"></span>
                    <span id="current-opening-eco" class="current-opening-eco"></span>
                  </div>
                  <span id="current-opening-category" class="current-opening-category"></span>
                  <div id="current-opening-stats" class="current-opening-stats"></div>
                  <div id="current-opening-moves" class="current-opening-moves"></div>
                  <p id="current-opening-description" class="current-opening-description"></p>
                </div>
              </div>

              <!-- Book Move Suggestion -->
              <div class="book-move-section">
                <h4>Buchzug-Vorschlag</h4>
                <div id="book-moves-list" class="book-moves-list"></div>
              </div>

              <!-- Opening Database Browser -->
              <div class="opening-browser-section">
                <div class="browser-controls">
                  <input type="text" id="opening-search" class="opening-search-input" placeholder="Eröffnung suchen (Name, ECO, Kategorie)...">
                  <select id="opening-category-filter" class="opening-category-filter">
                    <option value="all">Alle Kategorien</option>
                  </select>
                </div>
                <div id="opening-search-results" class="opening-search-results"></div>
                <div id="top-openings-list" class="top-openings-list"></div>
              </div>
            </div>
          </div>

          <!-- Shop Panel (Contextual) -->
          <div id="shop-panel" class="shop-panel bottom-sheet hidden" role="dialog" aria-label="Shop">
            <div class="sheet-handle" aria-hidden="true"></div>
            <div class="shop-header">
              <h2>Truppen anheuern</h2>
              <div class="shop-points">
                <span id="points-display" data-testid="points-display">15</span> Pkt
              </div>
            </div>

            <!-- Tutor Recommendations Section -->
            <div id="tutor-recommendations-section" class="tutor-recommendations-section">
              <button id="toggle-tutor-recommendations" class="btn-secondary full-width" style="padding: 8px; font-size: 0.9rem; margin-bottom: 1rem">
                💡 KI-Vorlagen anzeigen
              </button>
              <div id="tutor-recommendations-container" class="tutor-recommendations-container hidden">
                <!-- Templates will be injected here by JavaScript -->
              </div>
            </div>

            <div id="shop-buttons" class="shop-grid">
              <button class="shop-item" data-piece="p" data-cost="1" style="opacity: 1; pointer-events: auto;">
                <div class="shop-icon">♟️</div>
                <div class="shop-cost">1</div>
              </button>
              <button class="shop-item" data-piece="n" data-cost="3" style="opacity: 1; pointer-events: auto;">
                <div class="shop-icon">♞</div>
                <div class="shop-cost">3</div>
              </button>
              <button class="shop-item" data-piece="b" data-cost="3" style="opacity: 1; pointer-events: auto;">
                <div class="shop-icon">♝</div>
                <div class="shop-cost">3</div>
              </button>
              <button class="shop-item" data-piece="r" data-cost="5" style="opacity: 1; pointer-events: auto;">
                <div class="shop-icon">♜</div>
                <div class="shop-cost">5</div>
              </button>
              <button class="shop-item" data-piece="j" data-cost="6" style="opacity: 1; pointer-events: auto;">
                <div class="shop-icon">🦄</div>
                <div class="shop-cost">6</div>
              </button>
              <button class="shop-item" data-piece="a" data-cost="7" style="opacity: 1; pointer-events: auto;">
                <div class="shop-icon">🏰</div>
                <div class="shop-cost">7</div>
              </button>
              <button class="shop-item" data-piece="c" data-cost="8" style="opacity: 1; pointer-events: auto;">
                <div class="shop-icon">⚖️</div>
                <div class="shop-cost">8</div>
              </button>
              <button class="shop-item" data-piece="q" data-cost="9" style="opacity: 1; pointer-events: auto;">
                <div class="shop-icon">♛</div>
                <div class="shop-cost">9</div>
              </button>
              <button class="shop-item" data-piece="e" data-cost="12" style="opacity: 1; pointer-events: auto;">
                <div class="shop-icon">👼</div>
                <div class="shop-cost">12</div>
              </button>
            </div>
            <div id="selected-piece-display" class="shop-status">Wähle eine Figur zum Kaufen</div>

            <button id="finish-setup-btn" class="btn-primary full-width">Fertig</button>
          </div>
        </div>

        <!-- OVERLAY LAYER: Fullscreen menus and modals -->
        <div id="overlay-layer">
          <!-- Menu Overlay -->
          <div id="menu-overlay" class="fullscreen-overlay hidden">
            <div class="menu-content">
              <div class="menu-header">
                <h2>Menü</h2>
                <button id="menu-close-btn" class="close-icon-btn">×</button>
              </div>

              <div class="menu-grid">
                <div class="menu-section">
                  <h3>Spiel</h3>
                  <button id="restart-btn" class="menu-item">🔄 Neues Spiel</button>
                  <button id="puzzle-mode-btn" class="menu-item">🧩 Puzzles</button>
                  <button id="save-btn" class="menu-item">💾 Speichern</button>
                  <button id="load-btn" class="menu-item">📂 Laden</button>
                  <button id="analysis-mode-btn" class="menu-item">🔍 Analyse-Modus</button>
                  <button id="resign-btn" class="menu-item danger">🏳️ Aufgeben</button>
                  <button id="draw-offer-btn" class="menu-item warning">🤝 Remis anbieten</button>
                  <button id="export-pgn-btn" class="menu-item">📝 PGN exportieren</button>
                </div>

                <div class="menu-section">
                  <h3>Einstellungen</h3>

                  <div class="setting-row">
                    <label>Brett-Design</label>
                    <select id="theme-select" class="menu-select">
                      <option value="classic">Klassisch</option>
                      <option value="blue">Blau</option>
                      <option value="green">Grün</option>
                      <option value="dark">Dunkel</option>
                      <option value="wood">Holz</option>
                    </select>
                  </div>
                  <div class="setting-row">
                    <label>Schwierigkeit</label>
                    <select id="difficulty-select" class="menu-select">
                      <option value="beginner">Anfänger</option>
                      <option value="easy">Einfach</option>
                      <option value="medium">Mittel</option>
                      <option value="hard">Schwer</option>
                      <option value="expert">Experte</option>
                    </select>
                  </div>
                  <div class="setting-row">
                    <label>Zeit</label>
                    <select id="time-control-select" class="menu-select">
                      <option value="blitz3">Blitz 3+2</option>
                      <option value="blitz5" selected="">Blitz 5+3</option>
                      <option value="rapid10">Rapid 10+0</option>
                      <option value="rapid15">Rapid 15+10</option>
                      <option value="classical30">Klassisch 30+0</option>
                    </select>
                  </div>
                  <div class="setting-row">
                    <label>Sound</label>
                    <div class="volume-control">
                      <label class="toggle-switch">
                        <input type="checkbox" id="sound-toggle" checked="">
                        <span class="toggle-slider"></span>
                      </label>
                      <input type="range" id="volume-slider" min="0" max="100" value="30" class="volume-slider">
                      <span id="volume-value">30%</span>
                    </div>
                  </div>

                  <div class="setting-row">
                    <label>Tutor-Modus</label>
                    <select id="tutor-mode-select" class="menu-select">
                      <option value="standard">Standard (Tipps)</option>
                      <option value="guess_the_move">Rate den Zug!</option>
                    </select>
                  </div>

                  <div class="setting-row">
                    <label>KI-Mentor (Warnstufe)</label>
                    <select id="ki-mentor-level-select" class="menu-select">
                      <option value="OFF">Aus</option>
                      <option value="STANDARD" selected="">Standard (Nur Patzer)</option>
                      <option value="STRICT">Streng (Auch Fehler)</option>
                    </select>
                  </div>

                  <div class="setting-row" id="tutor-points-row">
                    <label>Tutor-Punkte</label>
                    <div id="tutor-points-display" class="stat-pill">0</div>
                  </div>
                  <div class="setting-row">
                    <label>KI-Persönlichkeit</label>
                    <select id="ai-personality-select" class="menu-select">
                      <option value="balanced">⚖️ Ausgeglichen</option>
                      <option value="aggressive">⚔️ Aggressiv</option>
                      <option value="defensive">🛡️ Defensiv</option>
                      <option value="positional">♟️ Positionell</option>
                    </select>
                  </div>
                </div>

                <div class="menu-section">
                  <h3>Extras</h3>
                  <button id="stats-btn" class="menu-item">📊 Statistiken</button>

                  <button id="help-btn" class="menu-item">📖 Hilfe / Tutorial</button>
                </div>
              </div>
            </div>
          </div>

          <!-- Info Overlay (Log, History) -->
          <div id="info-overlay" class="fullscreen-overlay hidden">
            <div class="info-content">
              <div class="menu-header">
                <h2>Spielinfo</h2>
                <button id="info-close-btn" class="close-icon-btn">×</button>
              </div>
              <div class="info-tabs">
                <button class="tab-btn active" data-tab="history">Historie</button>
                <button class="tab-btn" data-tab="log">Log</button>
              </div>
              <div id="tab-history" class="tab-pane active">
                <div id="move-history" class="history-list"></div>
              </div>
              <div id="tab-log" class="tab-pane">
                <div id="log-panel" class="log-list"></div>
              </div>
            </div>
          </div>

          <!-- Overlays (Game Over, Promotion, etc.) -->
          <div id="game-over-overlay" class="modal-overlay hidden">
            <div class="modal-content">
              <h2 id="winner-text">Spiel beendet</h2>
              <div id="game-over-stats" class="game-over-stats" style="
                  margin: 1rem 0;
                  padding: 1rem;
                  background: rgba(255, 255, 255, 0.05);
                  border-radius: 8px;
                  display: none;
                "></div>
              <button id="postgame-analysis-btn" class="btn-primary" style="margin-top: 0.5rem; display: none">
                📊 Nachspiel-Analyse
              </button>
              <button id="restart-btn-overlay" class="btn-primary">Neues Spiel</button>
              <button id="close-game-over-btn" class="btn-secondary">Schließen</button>
            </div>
          </div>

          <div id="promotion-overlay" class="modal-overlay hidden">
            <div class="modal-content">
              <h2>Beförderung</h2>
              <div id="promotion-options" class="promotion-grid"></div>
            </div>
          </div>

          <!-- Puzzle Menu Overlay -->
          <div id="puzzle-menu-overlay" class="fullscreen-overlay hidden">
            <div class="menu-content puzzle-menu-container">
              <div class="menu-header">
                <h2>Puzzles</h2>
                <button id="puzzle-menu-close-btn" class="close-icon-btn">×</button>
              </div>
              <div id="puzzle-menu-list" class="puzzle-grid">
                <!-- Puzzles injected by JS -->
              </div>
            </div>
          </div>

          <!-- Statistics Overlay -->
          <div id="stats-overlay" class="fullscreen-overlay hidden">
            <div class="stats-content">
              <div class="stats-header">
                <h2>Statistiken</h2>
                <button id="stats-close-btn" class="close-icon-btn">×</button>
              </div>
              <div class="stats-grid">
                <div class="stat-card">
                  <div class="stat-label">Genauigkeit</div>
                  <div id="stat-accuracy" class="stat-value">--%</div>
                </div>
                <div class="stat-card">
                  <div class="stat-label">Beste Züge</div>
                  <div id="stat-best-moves" class="stat-value">0</div>
                </div>
                <div class="stat-card">
                  <div class="stat-label">Material</div>
                  <div id="stat-material" class="stat-value">0</div>
                </div>
                <div class="stat-card">
                  <div class="stat-label">Geschätzte Elo</div>
                  <div id="stat-elo" class="stat-value">600</div>
                </div>
              </div>
            </div>
          </div>

          <!-- Puzzle Panel -->
          <div id="puzzle-overlay" class="puzzle-panel hidden">
            <div class="puzzle-content">
              <h2 id="puzzle-title">Puzzle Titel</h2>
              <p id="puzzle-description">Beschreibung...</p>
              <div class="puzzle-status" id="puzzle-status">Weiß am Zug</div>
              <div class="puzzle-buttons">
                <button id="puzzle-next-btn" class="btn-primary hidden">Nächstes Puzzle</button>
                <button id="puzzle-exit-btn" class="btn-secondary">Beenden</button>
              </div>
            </div>
          </div>
        </div>

        <!-- Help Overlay -->
        <div id="help-overlay" class="fullscreen-overlay hidden">
          <div class="info-content">
            <div class="menu-header">
              <h2>Hilfe &amp; Regeln</h2>
              <button id="close-help-btn" class="close-icon-btn">×</button>
            </div>
            <div class="help-body" style="padding: 20px; overflow-y: auto; max-height: 70vh">
              <h3>Spielablauf</h3>
              <p>Schach 9x9 ist eine Variante auf einem größeren Brett mit neuen Figuren.</p>
              <h4>1. Setup-Phase</h4>
              <ul>
                <li>
                  <strong>König platzieren:</strong> Wähle einen 3x3 Bereich für deinen König.
                </li>
                <li><strong>Truppen kaufen:</strong> Nutze deine Punkte, um Figuren zu kaufen.</li>
                <li>
                  <strong>Aufstellung:</strong> Platziere deine gekauften Figuren in deinem Bereich.
                </li>
              </ul>
              <h4>2. Neue Figuren</h4>
              <ul>
                <li><strong>Kanzler (C):</strong> Zieht wie Turm + Springer.</li>
                <li><strong>Erzbischof (A):</strong> Zieht wie Läufer + Springer.</li>
              </ul>
            </div>
          </div>
        </div>

        <!-- Confirmation Overlay -->
        <div id="confirmation-overlay" class="modal-overlay hidden">
          <div class="modal-content">
            <h2 id="confirmation-title">Bestätigung</h2>
