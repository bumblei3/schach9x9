            <!-- Content Area -->
            <main class="menu-content-area">
              <!-- Play View -->
              <div id="view-play" class="menu-view active">
                <h2 class="section-title">Neues Spiel</h2>
                <p class="section-subtitle">Starte schnell — oder entdecke weitere Modi.</p>

                <section class="menu-section menu-section-featured" aria-labelledby="featured-modes-label">
                  <h3 id="featured-modes-label" class="menu-section-label">Empfohlen</h3>
                  <div class="gamemode-grid gamemode-grid-featured">
                    <div class="gamemode-card hidden" id="main-menu-continue-btn">
                      <div class="card-icon">📂</div>
                      <div class="card-title">Fortsetzen</div>
                      <div class="card-desc">Setze dein zuletzt gespeichertes Spiel fort.</div>
                    </div>

                    <div class="gamemode-card" id="campaign-start-btn">
                      <span class="card-tag tag-new">Kampagne</span>
                      <div class="card-icon">⚔️</div>
                      <div class="card-title">Kampagne</div>
                      <div class="card-desc">
                        Erlebe eine epische Geschichte und kämpfe gegen immer stärkere Gegner.
                      </div>
                    </div>

                    <button type="button" class="gamemode-card" data-init-mode="classic" data-init-points="0" data-mode="classic">
                      <div class="card-icon">🏰</div>
                      <div class="card-title">Klassisch 9×9</div>
                      <div class="card-desc">
                        Das volle Erlebnis mit Erzbischof, Kanzler und 3 Korridoren.
                      </div>
                    </button>

                    <button type="button" class="gamemode-card gamemode-card-daily" data-init-mode="daily-puzzle" data-init-points="0" data-mode="daily-puzzle">
                      <span class="card-tag tag-pro">Täglich</span>
                      <div class="card-icon daily-streak-icon" aria-hidden="true">📅</div>
                      <div class="card-title">Tägliches Puzzle</div>
                      <div class="card-desc">
                        Ein neues Puzzle jeden Tag — baue deine Siegesserie auf.
                      </div>
                      <div class="daily-streak-row">
                        <span class="daily-badge daily-streak-pill" id="daily-puzzle-streak" style="display: none"></span>
                        <span class="daily-badge" id="daily-puzzle-badge" style="display: none">Heute gelöst ✓</span>
                      </div>
                    </button>
                  </div>
                </section>

                <section class="menu-section menu-section-more" aria-labelledby="more-modes-label">
                  <button type="button" id="toggle-more-modes" class="menu-more-toggle" aria-expanded="false" aria-controls="more-modes-grid">
                    <span id="more-modes-label">Mehr Modi</span>
                    <span class="menu-more-chevron" aria-hidden="true">▾</span>
                  </button>
                  <div id="more-modes-grid" class="gamemode-grid menu-more-grid is-collapsed" hidden="">
                    <button type="button" class="gamemode-card" data-init-mode="setup" data-init-points="25" data-mode="setup">
                      <div class="card-icon">💰</div>
                      <div class="card-title">Truppen anheuern (9×9)</div>
                      <div class="card-desc">
                        Stelle deine eigene 9×9-Armee mit 25 Punkten zusammen.
                      </div>
                    </button>

                    <button type="button" class="gamemode-card" data-init-mode="upgrade" data-init-points="25" data-mode="upgrade">
                      <div class="card-icon">👑</div>
                      <div class="card-title">Klassisch 9×9 + Upgrades</div>
                      <div class="card-desc">
                        Starte mit dem klassischen Layout und 25 Punkten für Truppen-Verbesserungen.
                      </div>
                    </button>

                    <button type="button" class="gamemode-card" data-init-mode="upgrade8x8" data-init-points="15">
                      <div class="card-icon">💎</div>
                      <div class="card-title">8×8 + Upgrades</div>
                      <div class="card-desc">
                        Starte mit 15 Punkten auf einem Standard-Brett und verbessere deine Armee.
                      </div>
                    </button>

                    <button type="button" class="gamemode-card" data-init-mode="cross" data-init-points="15" data-mode="cross">
                      <div class="card-icon">✝️</div>
                      <div class="card-title">Kreuz-Modus</div>
                      <div class="card-desc">
                        Kämpfe auf einem kreuzförmigen Brett – nur die Mitte zählt!
                      </div>
                    </button>

                    <button type="button" class="gamemode-card" data-init-mode="standard8x8" data-init-points="0" data-mode="standard8x8">
                      <div class="card-icon">♟️</div>
                      <div class="card-title">Standard 8×8</div>
                      <div class="card-desc">Klassisches Schachbrett, aber mit 9×9-Regeln.</div>
                    </button>

                    <button type="button" class="gamemode-card" data-init-mode="puzzle" data-init-points="0" data-mode="puzzle">
                      <span class="card-tag tag-pro">Training</span>
                      <div class="card-icon">🧩</div>
                      <div class="card-title">Puzzle-Modus</div>
                      <div class="card-desc">
                        Löse taktische Aufgaben und verbessere dein Spiel.
                      </div>
                    </button>

                    <button type="button" class="gamemode-card" data-init-mode="opening-trainer" data-init-points="0" data-mode="opening-trainer">
                      <div class="card-icon">📖</div>
                      <div class="card-title">Eröffnungs-Trainer</div>
                      <div class="card-desc">
                        Trainiere Eröffnungen aus dem Buch – finde den richtigen Zug.
                      </div>
                    </button>
                  </div>
                </section>
              </div>

              <!-- Learn View -->
              <div id="view-learn" class="menu-view">
                <h2 class="section-title">Lernen &amp; Regeln</h2>
                <div class="gamemode-grid">
                  <div class="gamemode-card" id="start-tutorial-btn">
                    <div class="card-icon">🎓</div>
                    <div class="card-title">Interaktives Tutorial</div>
                    <div class="card-desc">
                      Lerne die Regeln, Figuren und Special Moves in einer geführten Tour.
                    </div>
                  </div>
                </div>
              </div>

              <!-- Settings View -->
              <div id="view-settings" class="menu-view">
                <h2 class="section-title">Einstellungen</h2>
                <div class="settings-grid">
                  <div class="setting-group">
                    <h3>Darstellung</h3>
                    <div class="setting-row">
                      <label>Brett-Design</label>
                      <select id="theme-select" class="menu-select">
                        <option value="classic">Klassisch</option>
                        <option value="blue">Blau</option>
                        <option value="green">Grün</option>
                        <option value="dark">Dunkel</option>
                        <option value="wood">Holz</option>
                      </select>
                    </div>
                    <div class="setting-row" style="margin-top: 10px">
                      <label>Figuren-Skin</label>
                      <select id="skin-selector-menu" class="menu-select" onchange="
                          document.getElementById('skin-selector').value = this.value;
                          document
                            .getElementById('skin-selector')
                            .dispatchEvent(new Event('change'));
                        ">
                        <option value="classic">Klassisch</option>
                        <option value="modern">Modern</option>
                        <option value="pixel">Pixel</option>
                        <option value="infernale">Infernale</option>
                        <option value="wood">Holz</option>
                        <option value="neon">Neon</option>
                        <option value="minimalist">Minimalistisch</option>
                        <option value="frost">Frost</option>
                      </select>
                    </div>
                  </div>

                  <div class="setting-group">
                    <h3>Spiel &amp; Sound</h3>
                    <div class="setting-row">
                      <label>Sound</label>
                      <div class="volume-control">
                        <label class="toggle-switch">
                          <input type="checkbox" id="sound-toggle" checked="">
                          <span class="toggle-slider"></span>
                        </label>
                      </div>
                    </div>
                    <div class="setting-row" style="margin-top: 10px">
                      <label>Lautstärke</label>
                      <input type="range" id="volume-slider" min="0" max="100" value="30" class="volume-slider">
                    </div>
                    <div class="setting-row" style="margin-top: 10px">
                      <label>Schwierigkeit</label>
                      <select id="difficulty-select" class="menu-select">
                        <option value="beginner">Anfänger</option>
                        <option value="easy">Einfach</option>
                        <option value="medium">Mittel</option>
                        <option value="hard">Schwer</option>
                        <option value="expert">Experte</option>
                      </select>
                    </div>
                  </div>

                  <div class="setting-group">
                    <h3>KI &amp; Hilfe</h3>
                    <div class="setting-row">
                      <label>KI-Persönlichkeit</label>
                      <select id="ai-personality-select" class="menu-select">
                        <option value="balanced">⚖️ Ausgeglichen</option>
                        <option value="aggressive">⚔️ Aggressiv</option>
                        <option value="defensive">🛡️ Defensiv</option>
                        <option value="positional">♟️ Positionell</option>
                      </select>
                    </div>
                    <div class="setting-row" style="margin-top: 10px">
                      <label>KI-Mentor</label>
                      <select id="ki-mentor-level-select" class="menu-select">
                        <option value="OFF">Aus</option>
                        <option value="STANDARD" selected="">Standard (Nur Patzer)</option>
                        <option value="STRICT">Streng (Auch Fehler)</option>
                      </select>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Credits View -->
              <div id="view-credits" class="menu-view">
                <h2 class="section-title">Credits</h2>
                <p>Entwickelt mit ❤️ vom Google Deepmind Team</p>
              </div>
            </main>
          </div>
        </div>

        <!-- Hidden elements for compatibility if needed -->
        <div id="controls-wrapper" class="hidden"></div>
        <div id="quick-actions" class="hidden"></div>
        <div id="info-tabs-container" class="hidden"></div>
      </div>

      <script type="module" src="scripts/debug.ts"></script>
      <script type="module" src="js/main.ts"></script>
    </div>
  

"
`;

