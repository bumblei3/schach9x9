{
  "name": "schach9x9",
  "version": "1.2.0",
  "description": "Schach 9x9 Spiel",
  "type": "module",
  "scripts": {
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest --run",
    "train": "node opening-book-trainer-real.cjs",
    "train:fast": "node opening-book-trainer-real.cjs --games 50",
    "train:thorough": "node opening-book-trainer-real.cjs --games 500",
    "build": "npx vite build",
    "start": "npx serve .",
    "dev": "npx vite",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch",
    "test:visual": "npx playwright test --grep @visual",
    "test:visual:update": "npx playwright test --grep @visual --update-snapshots",
    "test:coverage": "vitest run --coverage",
    "changelog": "node scripts/changelog.mjs",
    "postinstall": "npm rebuild rolldown vite || true"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.0",
    "@types/three": "^0.182.0",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.5.0",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^17.6.0",
    "http-server": "^14.1.1",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "jsdoc": "^4.0.5",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vitest": "^4.0.17"
  },
  "dependencies": {
    "@axe-core/playwright": "^4.11.3",
    "three": "^0.184.0"
  },
  "overrides": {
    "undici": "^7.28.0",
    "js-yaml": "^3.15.0"
  }
}
